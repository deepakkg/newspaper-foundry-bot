LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4.1-mini
LLM_API_KEY=your_llm_api_key
TOPICS=coursera,Donald Trump,Narendra Modi,unlearning,performance review
TONES=funny,whimsical,nostalgic,witty,rant,serious
MAX_TWEET_CHARS=230
MAX_RETRIES=5
LLM_TIMEOUT_SECONDS=120
NEWS_ENABLED=true
NEWS_RECENCY_HOURS=48
NEWS_REGION=US
NEWS_LANGUAGE=en
POST_TO_BLUESKY=true
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your_bluesky_app_password
BLUESKY_SERVICE_URL=https://bsky.social
POST_TO_INSTAGRAM=false
INSTAGRAM_ACCOUNT_ID=your_instagram_account_id
INSTAGRAM_ACCESS_TOKEN=your_instagram_access_token
INSTAGRAM_GRAPH_BASE_URL=https://graph.instagram.com
INSTAGRAM_GRAPH_API_VERSION=v23.0
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=content-bot
POST_TO_X=false
X_API_KEY=your_x_api_key
X_API_KEY_SECRET=your_x_api_key_secret
X_ACCESS_TOKEN=your_x_access_token
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret
X_USERNAME=your_x_username
APPROVAL_TIMEOUT_MINUTES=90
TELEGRAM_NOTIFICATIONS_ENABLED=false
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
DISCORD_NOTIFICATIONS_ENABLED=false
DISCORD_WEBHOOK_URL=your_discord_webhook_url
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_CHANNEL_ID=your_discord_channel_id
DISCORD_APPROVER_USER_IDS=your_discord_user_id
GENERATED_IMAGE_DIR=generated-posts
LOG_FILE_PATH=logs/tweet-history.md
